<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="ring" android:thickness="10dp" android:useLevel="false">
            <solid android:color="#DFE6E9" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <rotate android:fromDegrees="270" android:toDegrees="270">
            <shape android:shape="ring" android:thickness="10dp" android:useLevel="true">
                <gradient android:endColor="#0984E3" android:startColor="#74B9FF" android:type="sweep" />
            </shape>
        </rotate>
    </item>
</layer-list>